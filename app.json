{
  "expo": {
    "name": "Salah",
    "slug": "salah",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-screen.png",
      "resizeMode": "cover",
      "backgroundColor": "#2D5016",
      "imageWidth": 200,
      "imageHeight": 200
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.salah.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "fetch",
          "processing",
          "remote-notification"
        ],
        "NSLocationWhenInUseUsageDescription": "Namaz vakitlerini doğru hesaplamak için konumunuza ihtiyacımız var.",
        "NSLocationAlwaysUsageDescription": "Namaz vakitlerini doğru hesaplamak için konumunuza ihtiyacımız var.",
        "NSPhotoLibraryUsageDescription": "Profil fotoğrafı eklemek için fotoğraf kütüphanenize erişim gerekiyor.",
        "NSCameraUsageDescription": "Profil fotoğrafı çekmek için kameraya erişim gerekiyor.",
        "UILaunchScreen": {
          "backgroundColor": "#2D5016"
        },
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSExceptionDomains": {
            "supabase.co": {
              "NSExceptionAllowsInsecureHTTPLoads": false,
              "NSIncludesSubdomains": true,
              "NSExceptionRequiresForwardSecrecy": true,
              "NSExceptionMinimumTLSVersion": "TLSv1.2",
              "NSThirdPartyExceptionRequiresForwardSecrecy": false
            }
          }
        }
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-logo.png",
        "backgroundColor": "#2D5016"
      },
      "package": "com.salah.app",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/app-logo.png",
          "color": "#2D5016",
          "sounds": [
            "./assets/sounds/fajr_ezan.mp3",
            "./assets/sounds/dhuhr_ezan.mp3",
            "./assets/sounds/asr_ezan.mp3",
            "./assets/sounds/maghrib_ezan.mp3",
            "./assets/sounds/isha_ezan.mp3"
          ]
        }
      ],
      [
        "expo-sensors",
        {
          "motionPermission": "Kıble yönünü doğru gösterebilmek için cihaz hareket sensörlerine erişim gerekiyor."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Namaz vakitlerini doğru hesaplamak için konumunuza ihtiyacımız var."
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Amiri-Regular.ttf",
            "./assets/fonts/Amiri-Bold.ttf",
            "./assets/fonts/ScheherazadeNew-Regular.ttf",
            "./assets/fonts/ScheherazadeNew-Bold.ttf"
          ]
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Profil fotoğrafı eklemek için fotoğraf kütüphanenize erişim gerekiyor.",
          "cameraPermission": "Profil fotoğrafı çekmek için kameraya erişim gerekiyor."
        }
      ],
      "expo-router"
    ],
    "extra": {
      "eas": {
        "projectId": "6437d0ae-1f94-41c8-9047-ade881444e1e"
      },
      "router": {}
    },
    "scheme": "salah",
    "owner": "asy"
  }
}
